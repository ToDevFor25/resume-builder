  // localStorage fallback (dev / pre-Clerk)
  localStorage.setItem('arx_profile', JSON.stringify({
    currentLevel: profile.currentLevel,
    targetLevel:  profile.targetLevel,
    focus:        profile.focus,
    onboarded:    true,
