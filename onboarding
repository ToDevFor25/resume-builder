}

function skipOnboarding() {
  localStorage.setItem('arx_profile', JSON.stringify({
    currentLevel: 'leadership',
    targetLevel:  'executive',
    focus:        'operations',
    onboarded:    false,
    savedAt:      new Date().toISOString()
  }));
  window.location.href = '/dashboard';
}
