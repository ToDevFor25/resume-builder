        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-q">What counts as a "use"?<svg viewBox="0 0 14 14"><path d="M7 2v10M2 7h10"/></svg></div>
          <div class="faq-a">One run through any tool is one use. For the Resume Optimizer, that's one full optimization. For SeeThrough, that's one job posting analyzed. For Interview Coach, that's one session or one refiner run. For Reference Writer, that's one letter generated. Uses reset on the 1st of each month.</div>
        </div>
        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-q">When does billing start?<svg viewBox="0 0 14 14"><path d="M7 2v10M2 7h10"/></svg></div>
          <div class="faq-a">Billing starts when you upgrade. Annual plans are billed upfront for the full year. Monthly plans renew on the same day each month. You can cancel anytime — we don't believe in retention dark patterns.</div>
        </div>
        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-q">What's the difference between Starter and Active Search?<svg viewBox="0 0 14 14"><path d="M7 2v10M2 7h10"/></svg></div>
          <div class="faq-a">Starter is for paced exploration — 20 uses per tool per month is plenty for most people casually looking. Active Search is for the person who is all-in on their job search and wants to use every tool without thinking about limits. If you're submitting multiple applications a week, Active Search pays for itself quickly.</div>
        </div>
        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-q">Do I need the Interview Pack if I'm on Active Search?<svg viewBox="0 0 14 14"><path d="M7 2v10M2 7h10"/></svg></div>
          <div class="faq-a">No — Active Search includes unlimited Interview Coach. The Interview Pack is a standalone add-on for users on Free or Starter plans who want full Interview Coach access without upgrading their entire plan.</div>
        </div>
        <div class="faq-item" onclick="toggleFaq(this)">
          <div class="faq-q">Is my data safe?<svg viewBox="0 0 14 14"><path d="M7 2v10M2 7h10"/></svg></div>
          <div class="faq-a">Yes. Your resume and profile data are stored securely and used only to personalize your results. We never share your data with employers, recruiters, or third parties. See our <a href="/privacy" style="color:var(--accent);">Privacy Policy</a> for full details.</div>
        </div>
      </div>

    </div>
  </main>
</div>
<div class="toast" id="toast"></div>
<script>
let isAnnual=true, currentProfile=null;

function hideAuthGate(){const g=document.getElementById('auth-gate');g.classList.add('hidden');setTimeout(()=>g.style.display='none',350);}
function srSignOut(){sb.auth.signOut().then(()=>window.location.replace('/login'));}
let tt;function showToast(msg){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');clearTimeout(tt);tt=setTimeout(()=>el.classList.remove('show'),2800);}

(async()=>{
  const{data:{session},error}=await sb.auth.getSession();
  if(error||!session){window.location.replace('/login');return;}
  const user=session.user;
  const name=user.user_metadata?.full_name||user.user_metadata?.name||user.email?.split('@')[0]||'You';
  const initials=name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('sidebar-avatar').textContent=initials;
  document.getElementById('sidebar-name').textContent=name;
  const{data:profile}=await sb.from('profiles').select('*').eq('id',user.id).single();
  currentProfile=profile||{plan:'free'};
  const plan=currentProfile.plan||'free';
  const planLabel=plan==='active'?'Active Search':plan.charAt(0).toUpperCase()+plan.slice(1);
  document.getElementById('sidebar-plan').textContent=planLabel;
  document.getElementById('current-plan-banner').style.display='flex';
  document.getElementById('current-plan-text').textContent=`You're on the ${planLabel} plan`;
  updateCTAs(plan);
  hideAuthGate();
})();

function updateCTAs(plan){
  const ctaFree=document.getElementById('cta-free');
  const ctaStarter=document.getElementById('cta-starter');
  const ctaActive=document.getElementById('cta-active');
  // Reset
  [ctaFree,ctaStarter,ctaActive].forEach(b=>{b.className='plan-cta primary';b.disabled=false;});
  if(plan==='free'){
    ctaFree.className='plan-cta current';ctaFree.textContent='Current plan';
    ctaStarter.textContent='Upgrade to Starter';
    ctaActive.className='plan-cta secondary';ctaActive.textContent='Upgrade to Active Search';
  } else if(plan==='starter'){
    ctaFree.className='plan-cta secondary';ctaFree.textContent='Downgrade';
    ctaStarter.className='plan-cta current';ctaStarter.textContent='Current plan';
    ctaActive.className='plan-cta secondary';ctaActive.textContent='Upgrade to Active Search';
  } else if(plan==='active'){
    ctaFree.className='plan-cta secondary';ctaFree.textContent='Downgrade';
    ctaStarter.className='plan-cta secondary';ctaStarter.textContent='Downgrade';
    ctaActive.className='plan-cta current';ctaActive.textContent='Current plan';
  }
}

function toggleBilling(){
  isAnnual=!isAnnual;
  document.getElementById('billing-toggle').classList.toggle('on',isAnnual);
  // Starter
  document.getElementById('starter-price').textContent=isAnnual?'$8':'$12';
  document.getElementById('starter-note').textContent=isAnnual?'billed $99/yr — 2 months free':'billed monthly';
  // Active
  document.getElementById('active-price').textContent=isAnnual?'$33':'$39';
  document.getElementById('active-note').textContent=isAnnual?'billed $390/yr — cancel anytime':'billed monthly — cancel anytime';
}

function handleCTA(plan){
  // STRIPE STUB — replace with Stripe Checkout links after LLC/Stripe setup
  const msgs={
    free:'To downgrade, contact billing@stretchrole.com',
    starter:'Stripe coming soon — email billing@stretchrole.com to upgrade',
    active:'Stripe coming soon — email billing@stretchrole.com to upgrade',
    interview_pack:'Stripe coming soon — email billing@stretchrole.com to add Interview Pack',
  };
  showToast(msgs[plan]||'Contact billing@stretchrole.com');
}

function toggleFaq(el){el.classList.toggle('open');}
</script>
</body>
