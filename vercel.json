{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/app",         "destination": "/app.html" },
    { "source": "/dashboard",   "destination": "/ascendrx.html" },
    { "source": "/onboarding",  "destination": "/onboarding.html" },
